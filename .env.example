APP_ENV=local
LOG_LEVEL=INFO

# Presigned GET/PUT URL validation. Comma-separate exact hostnames; do not add
# schemes, paths, or wildcard domains.
ALLOWED_STORAGE_HOSTS=example-bucket.s3.ap-northeast-2.amazonaws.com
# Set this for path-style S3 URLs whose path starts with /<bucket>/.
STORAGE_BUCKET=

# Input and network limits.
MAX_IMAGE_BYTES=10485760
MAX_IMAGE_DIMENSION=4096
STORAGE_TIMEOUT_SECONDS=30
ANALYSIS_TIMEOUT_SECONDS=60
PROCESSING_TIMEOUT_SECONDS=600
PROMPT_EDIT_TIMEOUT_SECONDS=600

# Create a new key locally and never commit or send it in chat.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Absolute path to the official FaceShield checkout on the same host. The API
# invokes execute.sh through its separate Python 3.8/CUDA conda environment.
FACESHIELD_REPO_PATH=
FACESHIELD_COMMAND=conda run --no-capture-output -n faceshield bash execute.sh
